{
  "name": "vscode-builder",
  "version": "0.1.0",
  "private": true,
  "description": "Browser-based generator that produces Intune-grade VS Code deployment bundles (Windows + macOS). Part of the Simsen Builder line.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "svelte-check --tsconfig ./tsconfig.json && vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json --watch"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^3.0.2",
    "@tsconfig/svelte": "^5.0.2",
    "@types/pako": "^2.0.3",
    "svelte": "^4.2.12",
    "svelte-check": "^3.6.7",
    "tslib": "^2.6.2",
    "typescript": "^5.4.3",
    "vite": "^5.2.0",
    "vite-plugin-singlefile": "^2.0.1"
  },
  "dependencies": {
    "pako": "^2.1.0"
  }
}
